{
  "expo": {
    "name": "CESI Missions",
    "slug": "expocesi",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "expocesi",
    "linking": {
      "prefixes": ["expocesi://"],
      "config": {
        "screens": {
          "(tabs)": {
            "screens": {
              "index": "home",
              "missions": "missions",
              "profil": "profil"
            }
          },
          "(auth)": {
            "screens": {
              "login": "login",
              "register": "register"
            }
          },
          "mission/[id]/index": "mission/:id",
          "mission/[id]/modify": "mission/:id/modify",
          "mission/[id]/delete": "mission/:id/delete",
          "mission/[id]/create": "mission/:id/create"
        }
      }
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cesi.missions.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.cesi.missions.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff",
          "sounds": [],
          "mode": "production"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d4437e94-113d-4dfc-b9de-cc75e17298b2"
      }
    },
    "owner": "octokling"
  }
}
