# ─── Supabase ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Expo / EAS ───────────────────────────────────────────────────────────────
# Token d'accès Expo (requis en mode CI/Docker pour éviter le prompt de login)
# Générer sur : https://expo.dev/accounts/[username]/settings/access-tokens
EXPO_TOKEN=your_expo_token_here

# ─── Réseau Docker ────────────────────────────────────────────────────────────
# Adresse IP locale de la machine hôte (ifconfig | grep "inet " sur macOS/Linux)
EXPO_HOST_IP=192.168.1.100
